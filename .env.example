# Variables de PRODUCCIÓN del contenedor (las lee docker-compose).
# En el servidor se copia a `.env` con los valores reales. NUNCA commitear .env.

# --- Django ---
# Generar una clave larga y aleatoria, p. ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=cambiar-por-una-clave-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=celtuc.scripthouse.com.ar,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://celtuc.scripthouse.com.ar
CORS_ALLOWED_ORIGINS=https://celtuc.scripthouse.com.ar

# --- Base de datos (Postgres central del VPS, dentro de la red Docker "web") ---
# La clave debe ser la MISMA que se definió al crear el usuario en Postgres.
DATABASE_URL=postgresql://celtuc:CLAVE-DB-AQUI@postgres:5432/celtuc?sslmode=disable
DATABASE_CONN_MAX_AGE=60

# --- Gunicorn ---
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
