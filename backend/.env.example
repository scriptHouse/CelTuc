# Variables para correr el backend en LOCAL (manage.py runserver).
# Copiar a backend/.env y ajustar. En produccion las variables viven en el
# .env de la raiz del proyecto (lo lee docker-compose); ver .env.example raiz.

SECRET_KEY=django-insecure-dev-key-solo-para-desarrollo-cambiar
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sin DATABASE_URL el backend usa SQLite local (backend/db.sqlite3), cero config.
# Para apuntar a un Postgres local, descomenta y ajusta:
# DATABASE_URL=postgresql://celtuc:clave@localhost:5432/celtuc

# Email (SMTP) — OPCIONAL, solo para "Enviar comprobante por email".
# Si no lo configuras, el envio queda deshabilitado (el resto del sistema anda igual).
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tucorreo@gmail.com
# EMAIL_HOST_PASSWORD=una-clave-de-aplicacion
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# DEFAULT_FROM_EMAIL=tucorreo@gmail.com
